generator client {
  provider = "prisma-client-js"
  output   = "./__generated__"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email    String @unique
  userName String @map("user_name")
  password String

  notification Notification[] @relation("user_notification")

  lesson Lesson[] @relation("user_lesson")

  role     UserRole? @default(USER)
  userLang UserLang? @default(UZ) @map("user_lang")

  tokens Token? @relation("user_tokens")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Token {
  id String @id @default(uuid())

  refreshToken String? @map("refresh_token")
  accessToken  String? @map("access_token")

  user   User   @relation("user_tokens", fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @map("user_id")

  @@map("tokens")
}

model Lesson {
  id String @id @default(uuid())

  title String

  words Word[] @relation("words_lesson")

  user   User   @relation("user_lesson", fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("lessons")
}

model Word {
  id String @id @default(uuid())

  kanji         String
  translation   String
  transcription String
  example       String
  jlptLevel     String @map("jlpt_level")

  lesson   Lesson @relation("words_lesson", fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String @map("lesson_id")

  @@map("words")
}

model Notification {
  id String @id @default(uuid())

  message String

  user   User?   @relation("user_notification", references: [id], fields: [userId], onDelete: Cascade)
  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

enum UserRole {
  ADMIN
  STUDENT
  TEACHER
  USER
}

enum UserLang {
  UZ
  RU
  JA
  EN
}
