# INTEGRATION TESTS #
#####################

### Test conflict scenario - overlapping times
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "MONDAY",
  "startTime": "10:30",
  "endTime": "12:30",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "This should conflict if user already has 10:00-12:00 or 11:00-13:00"
}

### Test full day availability
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "SATURDAY",
  "fullDay": true,
  "type": "REGULAR",
  "notes": "Available all Saturday"
}

### Test unavailable day
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "SUNDAY",
  "startTime": null,
  "endTime": null,
  "fullDay": false,
  "type": "REGULAR",
  "reason": "Day off",
  "notes": "Not available Sundays"
}

### Test teacher self-submission (should be PENDING)
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{teacher_cookie}}

{
  "dayOfWeek": "TUESDAY",
  "startTime": "13:00",
  "endTime": "18:00",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "Afternoon teaching availability"
}

### Test student access (should only see own records)
GET {{url}}/user-availability
Content-Type: application/json
Cookie: {{student_cookie}}