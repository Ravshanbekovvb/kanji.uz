###########
# EVENT   #
###########

### Get all events (with pagination)
GET {{url}}/events?page=1&limit=10
Content-Type: application/json
Cookie: {{cookie}}

### Get all events with search/filter
GET {{url}}/events?name=Summer&startDate=2025-07-01&endDate=2025-09-30
Content-Type: application/json
Cookie: {{cookie}}

### Get events with recurring filter
GET {{url}}/events?isRecurring=true
Content-Type: application/json
Cookie: {{cookie}}

### Get a specific event by ID
GET {{url}}/events/cmarz7rb9000210dr6ojo0b7q
Content-Type: application/json
Cookie: {{cookie}}

### Create a new event
POST {{url}}/events
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Summer Break",
  "startDate": "2025-07-15",
  "endDate": "2025-08-31",
  "isRecurring": false,
  "notes": "Annual summer vacation period",
  "branchId": "cmarz7rb9000110dr6ojo0a9p"
}

### Create a recurring event
POST {{url}}/events
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Weekly Staff Meeting",
  "startDate": "2025-06-01",
  "endDate": "2025-12-31",
  "isRecurring": true,
  "notes": "Occurs every Monday at 9am"
}

### Update an event
PATCH {{url}}/events/cmarz7rb9000210dr6ojo0b7q
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Extended Summer Break",
  "startDate": "2025-07-10",
  "endDate": "2025-09-05",
  "notes": "Extended due to facility renovations"
}

### Update just the name of an event
PATCH {{url}}/events/cmarz7rb9000210dr6ojo0b7q
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Revised Summer Break"
}

### Delete an event
DELETE {{url}}/events/cmarz7rb9000210dr6ojo0b7q
Content-Type: application/json
Cookie: {{cookie}}

