@url = http://localhost:3000/api
@cookie =
@teacher_cookie =
@student_cookie =

#################
# USER PROFILE  #
#################

### Get current user's profile information
GET {{url}}/users/me
Content-Type: application/json

###########
# STUDENT #
###########

### Get all students (with pagination)
GET {{url}}/students?page=1&limit=10
Content-Type: application/json

### Get all students with search/filter
GET {{url}}/students?name=佐藤&gradeYear=1
Content-Type: application/json
Cookie: {{cookie}}

### Get a specific student by ID
GET {{url}}/students/cmarz7rcd000c10dr28ej8a1j
Content-Type: application/json
Cookie: {{cookie}}

### Create a new student
POST {{url}}/students
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Taro Yamada",
  "kanaName": "ヤマダタロウ",
  "studentTypeId": "cmarz7rb9000110dr6ojo0a9p",
  "gradeYear": 2,
  "lineId": "taro_line123",
  "notes": "Transfer student from Tokyo",
  "username": "taroy2023",
  "password": "password123",
  "email": "taro@example.com",
  "branchIds": ["cmarz7rb9000110dr6ojo0a9p", "cln2x5abcd00010abc123def9"]
}

### Update a student
PATCH {{url}}/students/cmas08xhw0005101w54ztl6sd
Content-Type: application/json
Cookie: {{cookie}}

{
  "name": "Taro Suzuki",
  "kanaName": "スズキタロウ",
  "username": "tarosuzuki2023",
  "password": "newpassword123",
  "email": "tarosuzuki@example.com",
  "gradeYear": 3,
  "notes": "Updated information",
  "branchIds": ["cmarz7rb9000110dr6ojo0a9p"]
}

### Delete a student
DELETE {{url}}/students/cmas07pnk0002101wxjv0b0kp
Content-Type: application/json
Cookie: {{cookie}}

### Update student password (self-service)
PATCH {{url}}/students/me/password
Content-Type: application/json
Cookie: {{cookie}}

{
  "currentPassword": "currentpassword123",
  "newPassword": "newpassword456",
  "confirmPassword": "newpassword456"
}

