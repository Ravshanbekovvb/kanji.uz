# ----------------------------------------------------------------------------------------------------------------

######################
# USER AVAILABILITY  #
######################

### Get all availability records (with pagination)
GET {{url}}/user-availability?page=1&limit=10
Content-Type: application/json
Cookie: {{cookie}}

### Get availability filtered by user
GET {{url}}/user-availability?userId=cm1234567890abcdef123456
Content-Type: application/json
Cookie: {{cookie}}

### Get availability filtered by type and status
GET {{url}}/user-availability?type=REGULAR&status=APPROVED
Content-Type: application/json
Cookie: {{cookie}}

### Get availability for specific day of week
GET {{url}}/user-availability?dayOfWeek=MONDAY&type=REGULAR
Content-Type: application/json
Cookie: {{cookie}}

### Get exception availability for date range
GET {{url}}/user-availability?type=EXCEPTION&startDate=2024-01-01&endDate=2024-02-29
Content-Type: application/json
Cookie: {{cookie}}

### Get pending availability records (admin view)
GET {{url}}/user-availability?status=PENDING
Content-Type: application/json
Cookie: {{cookie}}

### Get a specific availability record by ID
GET {{url}}/user-availability/cm2345678901bcdef234567a
Content-Type: application/json
Cookie: {{cookie}}

### Create regular availability - Full day Monday
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "MONDAY",
  "fullDay": true,
  "type": "REGULAR",
  "notes": "Available all day Monday"
}

### Create regular availability - Partial day Tuesday
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "TUESDAY",
  "startTime": "09:00",
  "endTime": "17:00",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "Available Tuesday 9AM-5PM"
}

### Create regular availability - Morning slot Wednesday
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "WEDNESDAY",
  "startTime": "09:00",
  "endTime": "12:00",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "Morning availability only"
}

### Create regular availability - Afternoon slot Wednesday
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "WEDNESDAY",
  "startTime": "13:00",
  "endTime": "17:00",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "Afternoon availability only"
}

### Create regular availability - Unavailable Thursday
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "dayOfWeek": "THURSDAY",
  "startTime": null,
  "endTime": null,
  "fullDay": false,
  "type": "REGULAR",
  "reason": "Weekly staff meeting",
  "notes": "Not available on Thursdays"
}

### Create exception availability - Available specific date
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "date": "2024-12-25",
  "startTime": "10:00",
  "endTime": "15:00",
  "fullDay": false,
  "type": "EXCEPTION",
  "reason": "Holiday availability",
  "notes": "Available Christmas Day morning/afternoon"
}

### Create exception availability - Unavailable specific date
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "date": "2024-01-15",
  "startTime": null,
  "endTime": null,
  "fullDay": false,
  "type": "EXCEPTION",
  "reason": "Medical appointment",
  "notes": "Not available all day"
}

### Create availability for specific user (admin only)
POST {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm3456789012cdef345678ab",
  "dayOfWeek": "FRIDAY",
  "startTime": "14:00",
  "endTime": "18:00",
  "fullDay": false,
  "type": "REGULAR",
  "notes": "Friday afternoon availability"
}

### Update an availability record
PATCH {{url}}/user-availability/cm2345678901bcdef234567a
Content-Type: application/json
Cookie: {{cookie}}

{
  "startTime": "10:00",
  "endTime": "16:00",
  "notes": "Updated time slot"
}

### Update availability status (admin only)
PATCH {{url}}/user-availability/cm2345678901bcdef234567a
Content-Type: application/json
Cookie: {{cookie}}

{
  "status": "APPROVED",
  "reason": "Approved by admin"
}

### Delete a specific availability record
DELETE {{url}}/user-availability/cm2345678901bcdef234567a
Content-Type: application/json
Cookie: {{cookie}}

### Batch delete availability records
DELETE {{url}}/user-availability
Content-Type: application/json
Cookie: {{cookie}}

{
  "availabilityIds": [
    "cm2345678901bcdef234567a",
    "cm3456789012cdef345678ab",
    "cm4567890123def456789abc"
  ]
}

####################
# BATCH OPERATIONS #
####################

### Batch create regular weekly availability
POST {{url}}/user-availability/batch
Content-Type: application/json
Cookie: {{cookie}}

{
  "type": "REGULAR",
  "overwriteExisting": true,
  "availability": [
    {
      "dayOfWeek": "MONDAY",
      "startTime": "09:00",
      "endTime": "17:00",
      "fullDay": false,
      "notes": "Monday availability"
    },
    {
      "dayOfWeek": "TUESDAY",
      "startTime": "09:00",
      "endTime": "17:00",
      "fullDay": false,
      "notes": "Tuesday availability"
    },
    {
      "dayOfWeek": "WEDNESDAY",
      "startTime": "09:00",
      "endTime": "12:00",
      "fullDay": false,
      "notes": "Wednesday morning only"
    },
    {
      "dayOfWeek": "WEDNESDAY",
      "startTime": "13:00",
      "endTime": "17:00",
      "fullDay": false,
      "notes": "Wednesday afternoon only"
    },
    {
      "dayOfWeek": "FRIDAY",
      "fullDay": true,
      "notes": "Available all day Friday"
    }
  ]
}

### Batch create exception availability for vacation period
POST {{url}}/user-availability/batch
Content-Type: application/json
Cookie: {{cookie}}

{
  "type": "EXCEPTION",
  "overwriteExisting": true,
  "availability": [
    {
      "date": "2024-03-15",
      "startTime": null,
      "endTime": null,
      "fullDay": false,
      "reason": "Vacation",
      "notes": "Spring break - unavailable"
    },
    {
      "date": "2024-03-16",
      "startTime": null,
      "endTime": null,
      "fullDay": false,
      "reason": "Vacation",
      "notes": "Spring break - unavailable"
    },
    {
      "date": "2024-03-17",
      "startTime": null,
      "endTime": null,
      "fullDay": false,
      "reason": "Vacation",
      "notes": "Spring break - unavailable"
    }
  ]
}

### Batch create for specific user (admin only)
POST {{url}}/user-availability/batch
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm3456789012cdef345678ab",
  "type": "REGULAR",
  "overwriteExisting": false,
  "availability": [
    {
      "dayOfWeek": "MONDAY",
      "startTime": "10:00",
      "endTime": "14:00",
      "fullDay": false,
      "notes": "Part-time schedule"
    },
    {
      "dayOfWeek": "WEDNESDAY",
      "startTime": "10:00",
      "endTime": "14:00",
      "fullDay": false,
      "notes": "Part-time schedule"
    }
  ]
}

### Batch approve/reject availability records (admin only)
PATCH {{url}}/user-availability/batch
Content-Type: application/json
Cookie: {{cookie}}

{
  "availabilityIds": [
    "cm2345678901bcdef234567a",
    "cm3456789012cdef345678ab",
    "cm4567890123def456789abc"
  ],
  "status": "APPROVED",
  "reason": "Bulk approval for regular schedule"
}

### Batch reject availability records (admin only)
PATCH {{url}}/user-availability/batch
Content-Type: application/json
Cookie: {{cookie}}

{
  "availabilityIds": [
    "cm5678901234ef567890abcd",
    "cm6789012345f67890abcde1"
  ],
  "status": "REJECTED",
  "reason": "Conflicts with existing schedule"
}

######################
# CONFLICT CHECKING #
######################

### Check availability conflict for single user
POST {{url}}/user-availability/conflicts
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm1234567890abcdef123456",
  "date": "2024-02-15",
  "startTime": "10:00",
  "endTime": "12:00"
}

### Check availability for multiple users at once
GET {{url}}/user-availability/conflicts?userIds=cm1234567890abcdef123456,cm3456789012cdef345678ab,cm4567890123def456789abc&date=2024-02-15&startTime=10:00&endTime=12:00
Content-Type: application/json
Cookie: {{cookie}}

### Check availability for teacher and student pair
GET {{url}}/user-availability/conflicts?userIds=teacher_cm123456,student_cm789012&date=2024-02-20&startTime=14:00&endTime=15:30
Content-Type: application/json
Cookie: {{cookie}}

##################
# ADMIN DASHBOARD #
##################

### Get admin dashboard with pending approvals
GET {{url}}/user-availability/admin?status=PENDING&page=1&limit=20
Content-Type: application/json
Cookie: {{cookie}}

### Get all availability records for admin review
GET {{url}}/user-availability/admin?page=1&limit=50
Content-Type: application/json
Cookie: {{cookie}}

### Get availability records by type
GET {{url}}/user-availability/admin?type=EXCEPTION&status=APPROVED
Content-Type: application/json
Cookie: {{cookie}}

### Get availability records for specific user
GET {{url}}/user-availability/admin?userId=cm1234567890abcdef123456
Content-Type: application/json
Cookie: {{cookie}}

### Admin create/override availability directly (auto-approved)
POST {{url}}/user-availability/admin
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm3456789012cdef345678ab",
  "dayOfWeek": "MONDAY",
  "startTime": "09:00",
  "endTime": "17:00",
  "fullDay": false,
  "type": "REGULAR",
  "status": "APPROVED",
  "notes": "Admin override for regular Monday schedule",
  "overwriteExisting": true
}

### Admin create exception availability for user
POST {{url}}/user-availability/admin
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm4567890123def456789abc",
  "date": "2024-04-01",
  "startTime": null,
  "endTime": null,
  "fullDay": false,
  "type": "EXCEPTION",
  "status": "APPROVED",
  "reason": "Administrative leave",
  "notes": "Approved absence for training",
  "overwriteExisting": true
}

### Admin reject with reason
POST {{url}}/user-availability/admin
Content-Type: application/json
Cookie: {{cookie}}

{
  "userId": "cm5678901234ef567890abcd",
  "dayOfWeek": "FRIDAY",
  "startTime": "18:00",
  "endTime": "22:00",
  "fullDay": false,
  "type": "REGULAR",
  "status": "REJECTED",
  "reason": "Outside business hours policy",
  "notes": "Cannot approve evening availability"
}

